{
  "name": "@lgabriellp/claudet",
  "version": "2.11.0",
  "description": "Interactive worktree manager + Claude launcher",
  "license": "MIT",
  "type": "module",
  "bin": {
    "claudet": "./bin/claudet"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup": "bash scripts/install.sh",
    "build": "tsx scripts/build.ts",
    "prepack": "npm run build",
    "dev": "tsx src/claudet.ts",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --exclude 'src/evals/**'",
    "test:evals": "vitest run src/evals/",
    "test:evals:flaky": "tsx src/evals/flakiness.ts",
    "test:all": "vitest run",
    "test:watch": "vitest --exclude 'src/evals/**'",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {},
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "@octokit/rest": "^22.0.1",
    "@types/node": "^22.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260302.1",
    "esbuild": "^0.27.4",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "simple-git": "^3.32.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
